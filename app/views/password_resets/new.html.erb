<% content_for :title, page_title(t("auth.password_reset.new.title")) %>

<section class="auth-shell" aria-labelledby="password-reset-title">
  <p class="eyebrow"><%= t("auth.password_reset.new.eyebrow") %></p>
  <h1 id="password-reset-title" class="hero__title auth-shell__title"><%= t("auth.password_reset.new.title") %></h1>
  <p class="lede"><%= t("auth.password_reset.new.intro") %></p>

  <div class="form-shell">
    <%= form_with scope: :password_reset, url: password_reset_path, class: "form-stack" do |form| %>
      <div class="field-group">
        <%= form.label :email, t("auth.fields.email") %>
        <%= form.email_field :email, autocomplete: "email", required: true %>
      </div>

      <div class="actions-row">
        <%= form.submit t("auth.password_reset.new.submit"), class: "button" %>
      </div>
    <% end %>
  </div>
</section>
