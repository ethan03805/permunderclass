<footer class="site-footer">
  <div class="site-frame site-footer__grid">
    <section class="site-footer__section" aria-labelledby="footer-current-state-title">
      <p class="eyebrow"><%= t("footer.current_state.eyebrow") %></p>
      <h2 id="footer-current-state-title" class="site-footer__title"><%= t("footer.current_state.title") %></h2>
      <p class="site-footer__body"><%= t("footer.current_state.body") %></p>
    </section>

    <section class="site-footer__section" aria-labelledby="footer-copy-registry-title">
      <p class="eyebrow"><%= t("footer.copy_registry.eyebrow") %></p>
      <h2 id="footer-copy-registry-title" class="site-footer__title"><%= t("footer.copy_registry.title") %></h2>
      <p class="site-footer__body"><%= t("footer.copy_registry.body") %></p>
    </section>

    <section class="site-footer__section" aria-labelledby="footer-constraints-title">
      <p class="eyebrow"><%= t("footer.constraints.eyebrow") %></p>
      <h2 id="footer-constraints-title" class="site-footer__title"><%= t("footer.constraints.title") %></h2>
      <p class="site-footer__body"><%= t("footer.constraints.body") %></p>
    </section>
  </div>
</footer>
